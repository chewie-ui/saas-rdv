extends ../../layouts/index

block links

block content
    .content-wrapper
        .calendar-wrapper.container
            .calendar
                .calendar-header
                    .prev-month
                        button.btn#prevMonthBtn Prev
                    .this-month
                        h2
                    .next-month
                        button.btn#nextMonthBtn Next
                .calendar-body
                    .weekdays
                        //- Injected from JS
                    .days
                        //- Injected from JS

        .schedule-wrapper#scheduleWrapper
            .schedule
                .schedule-header
                    h2 Choose a schedule
                .schedule-body
                    .back-btn
                        svg(xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3")
                            path(d="M640-200 200-480l440-280v560Zm-80-280Zm0 134v-268L350-480l210 134Z")
                    .schedule-rows
                        //- Injected from JS



                                   

        .booking-wrapper#bookingWrapper(data-company-id=company._id)
            .booking
                .booking-header
                    h2 Confirm your booking
                .booking-body
                    .back-btn
                        svg(xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3")
                            path(d="M640-200 200-480l440-280v560Zm-80-280Zm0 134v-268L350-480l210 134Z")
                    .form-confirm
                        .field-container.flex.col
                            p Name
                            input.input(placeholder="Doe" id="bookingName")
                        .field-container.flex.col
                            p Surname
                            input.input(placeholder="John" id="bookingSurname")
                        .field-container.flex.col
                            p Email
                            input.input(placeholder="john.doe@company.com" id="bookingEmail")
                        .field-container.flex.col
                            p Phone
                            input.input(placeholder="+32 456 56 44 35" id="bookingPhone")
                        .field-container.flex.col
                            p Message
                            input.input(placeholder="Write something..." id="bookingMsg")
                    .booking-button
                        button.btn#confirmBooking Confirm

block scripts

    script(src="/js/layouts/index.js" type="module") 
    