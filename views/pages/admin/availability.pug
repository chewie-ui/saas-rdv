extends ../../layouts/admin

include ../../templates/calendar

block links
    link(rel="stylesheet", href="/css/components/admin/availability.admin.css")
    link(rel="stylesheet", href="/css/components/index/calendar.index.css")

block content
    .section__container.flex.col
        .availability-section.flex.col
            .availability-section__header
                h3 Set Default Working Hours
            .availability-section__body.flex
                .body-weekly-hour.flex.col
                    - const weekday = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"]
                    each day in currentCompany.schedule
                        .row-weekday.flex
                            .weekday-toggle.flex
                                .weekly-switcher
                                    label.switch
                                        input.input-weekday(type="checkbox" data-weekday-index=day.weekdayIndex data-company=currentCompany._id checked=!day.dayOff)
                                        span.slider
                                .weekly-hour__weekday= weekday[day.weekdayIndex] 
                            .weekly-hour__time.flex.col
                                if day.workingHours.length > 0
                                    each slot, index in day.workingHours
                                        .time-slot.flex-c(data-weekday-index=day.weekdayIndex)
                                            .start-hour.slot-hour
                                                .input.hour-container.start-hour-(data-hours="start")= slot.start || "08:00"
                                                .panel-availability
                                                    each hour in hours
                                                        .hour= hour

                                            div -
                                            .end-hour.slot-hour
                                                .input.hour-container.end-hour-(data-hours="end")= slot.end || "17:00"
                                                .panel-availability
                                                    each hour in hours
                                                        .hour= hour
                                            if index > 0
                                                .delete-time-slot(data-id=slot._id)
                                                    svg(xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3")
                                                        path(d="M280-120q-33 0-56.5-23.5T200-200v-520h-40v-80h200v-40h240v40h200v80h-40v520q0 33-23.5 56.5T680-120H280Zm400-600H280v520h400v-520ZM360-280h80v-360h-80v360Zm160 0h80v-360h-80v360ZM280-720v520-520Z")
   
                                else 
                                    .time-slot.flex-c
                                        .start-hour.slot-hour
                                            .input.hour-container.start-hour-(data-hours="start") 08:00
                                            .panel-availability
                                                each hour in hours
                                                    .hour= hour

                                        div -
                                        .end-hour.slot-hour
                                            .input.hour-container.end-hour-(data-hours="end") 17:00
                                            .panel-availability
                                                each hour in hours
                                                    .hour= hour
                            .weekly-hour__options.flex-c
                                .option.flex-c.option-add-plage
                                    svg(xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3")
                                        path(d="M440-440H200v-80h240v-240h80v240h240v80H520v240h-80v-240Z")

                                .option.flex-c
                                    svg(xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3")
                                        path(d="M360-240q-33 0-56.5-23.5T280-320v-480q0-33 23.5-56.5T360-880h360q33 0 56.5 23.5T800-800v480q0 33-23.5 56.5T720-240H360Zm0-80h360v-480H360v480ZM200-80q-33 0-56.5-23.5T120-160v-560h80v560h440v80H200Zm160-240v-480 480Z")

        .availability-section.flex.col
            .availability-section__header
                h3 Set your slot time per booking
            .availability-section__body.flex
                .time-slot__container
                    .slot-input__container#timeslotPanel
                        .input #{currentSlotTime || "30"}min
                        .panel
                            each time in timeSlot
                                .time(data-time=time) #{time}min

        .availability-section.flex.col
            .availability-section__header
                h3 Set your holidays in a click
            .availability-section__body.flex.col
                button.btn#addDaysOffBtn Add days off
                #holidaysBody.days-off__wrapper.flex.col
                    if daysOff
                        each day in daysOff.dates
                            .days-off__row.flex-c(data-date=day)
                                p.input= day.date.toLocaleDateString('fr-BE', { day: '2-digit', month: '2-digit', year: 'numeric'})
                                .days-off__schedule.flex-c
                                    if day.workingHours && day.workingHours.length > 0 && day.workingHours[0].start
                                        .time-slot.flex-c
                                            .start-hour.slot-hour
                                                .input.hour-container.start-hour-(data-hours="start")= day.workingHours[0].start
                                                .panel-availability
                                                    each hour in hours
                                                        .hour= hour

                                            div -
                                            .end-hour.slot-hour
                                                .input.hour-container.end-hour-(data-hours="end")= day.workingHours[0].end
                                                .panel-availability
                                                    each hour in hours
                                                        .hour= hour
                                            .delete-time-slot
                                                svg(xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3")
                                                    path(d="M280-120q-33 0-56.5-23.5T200-200v-520h-40v-80h200v-40h240v40h200v80h-40v520q0 33-23.5 56.5T680-120H280Zm400-600H280v520h400v-520ZM360-280h80v-360h-80v360Zm160 0h80v-360h-80v360ZM280-720v520-520Z")
                                    else
                                        p Day off
                                .days-off__actions.flex-c
                                    .days-off__button.schedule-btn
                                        svg(xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3")
                                            path(d="M440-440H200v-80h240v-240h80v240h240v80H520v240h-80v-240Z")
                                    .days-off__button.delete-btn
                                        svg(xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3")
                                            path(d="m336-280-56-56 144-144-144-143 56-56 144 144 143-144 56 56-144 143 144 144-56 56-143-144-144 144Z")

    #calendarWrapper
    template#plageTemplate
        .time-slot.flex-c
            .start-hour.slot-hour
                .input.hour-container.start-hour-(data-hours="start") 08:00
                .panel-availability
                    each hour in hours
                        .hour= hour

            div -
            .end-hour.slot-hour
                .input.hour-container.end-hour-(data-hours="end") 17:00
                .panel-availability
                    each hour in hours
                        .hour= hour
            .delete-time-slot
                svg(xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3")
                    path(d="M280-120q-33 0-56.5-23.5T200-200v-520h-40v-80h200v-40h240v40h200v80h-40v520q0 33-23.5 56.5T680-120H280Zm400-600H280v520h400v-520ZM360-280h80v-360h-80v360Zm160 0h80v-360h-80v360ZM280-720v520-520Z")
    +calendar()
    template#daysOffTemplate
        .days-off__rows
    template#dayOffRow
        .days-off__row.flex-c
            p.input
            .days-off__schedule.flex-c
                p.schedule-status Day off
            .days-off__actions.flex-c
                .days-off__button.schedule-btn   
                    svg(xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3")
                        path(d="M440-440H200v-80h240v-240h80v240h240v80H520v240h-80v-240Z")
                .days-off__button.delete-btn
                    svg(xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3")
                        path(d="M280-120q-33 0-56.5-23.5T200-200v-520h-40v-80h200v-40h240v40h200v80h-40v520q0 33-23.5 56.5T680-120H280Zm400-600H280v520h400v-520ZM360-280h80v-360h-80v360Zm160 0h80v-360h-80v360ZM280-720v520-520Z")



block scripts
    script(src="js/components/admin/availability.admin.js" type="module")
    script(src="js/templates/calendar.js" type="module")