extends ../../layouts/admin

block links
    link(rel="stylesheet", href="/css/layouts/history.css")

block content
    .page.page--history
        .history
            .history__container.flex.col
                .history__nav.flex-c.space-b
                    .flex
                        .selectmenu
                            .selectmenu__header
                                span Filters
                                <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3"><path d="M480-528 296-344l-56-56 240-240 240 240-56 56-184-184Z"/></svg>
                            .selectmenu__panel
                                .selectmenu__row Test dun poitn
                                .selectmenu__row Test dun poitn
                                .selectmenu__row Test dun poitn
                                .selectmenu__row Test dun poitn
                    .flex
                        .searchmenu
                            <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3"><path d="M779.38-153.85 528.92-404.31q-30 25.54-69 39.54t-78.38 14q-95.92 0-162.58-66.65-66.65-66.66-66.65-162.58 0-95.92 66.65-162.58 66.66-66.65 162.58-66.65 95.92 0 162.58 66.65 66.65 66.66 66.65 162.58 0 41.69-14.77 80.69t-38.77 66.69l250.46 250.47-28.31 28.3ZM381.54-390.77q79.61 0 134.42-54.81 54.81-54.8 54.81-134.42 0-79.62-54.81-134.42-54.81-54.81-134.42-54.81-79.62 0-134.42 54.81-54.81 54.8-54.81 134.42 0 79.62 54.81 134.42 54.8 54.81 134.42 54.81Z"/></svg>
                            input(placeholder="Search client")
                            .searchmenu__drop-icon.flex-c
                                <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3"><path d="m322.15-293.08-29.07-29.07L450.92-480 293.08-636.85l29.07-29.07L480-508.08l156.85-157.84 29.07 29.07L508.08-480l157.84 157.85-29.07 29.07L480-450.92 322.15-293.08Z"/></svg>

                table.table__schema
                    thead 
                        tr
                            th Id 
                            th Nom & Prenom
                            th Email
                            th Numero
                            th Date et horraire
                            th Notes
                            th Actions
                    tbody
                        each h in history
                            tr
                                td= h._id
                                td #{h.name} #{h.surname}
                                td #{h.email}
                                td #{h.phone}
                                td #{h.date} #{h.startTime} #{h.endTime}
                                td #{h.message}
                                td.btn-td.flex-c.j-start
                                    button.btn-icon.flex-c
                                        <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3"><path d="M480-160q-33 0-56.5-23.5T400-240q0-33 23.5-56.5T480-320q33 0 56.5 23.5T560-240q0 33-23.5 56.5T480-160Zm0-240q-33 0-56.5-23.5T400-480q0-33 23.5-56.5T480-560q33 0 56.5 23.5T560-480q0 33-23.5 56.5T480-400Zm0-240q-33 0-56.5-23.5T400-720q0-33 23.5-56.5T480-800q33 0 56.5 23.5T560-720q0 33-23.5 56.5T480-640Z"/></svg>
                    tfoot
                        tr
                            td
                                .table__schema-pagination.flex-c
                                    .pagination__showing Page #{currentPage}-#{totalPages}
                                    .pagination__btns.flex-c
                                        a(href=`/history?page=${currentPage - 1}`).btn-icon.flex-c
                                            <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3"><path d="M560-240 320-480l240-240 56 56-184 184 184 184-56 56Z"/></svg>
                                        a(href=`/history?page=${currentPage + 1}`).btn-icon.flex-c
                                            <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3"><path d="M504-480 320-664l56-56 240 240-240 240-56-56 184-184Z"/></svg>


block scripts
    script(src="/js/layouts/history.js" type="module")