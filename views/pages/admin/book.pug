extends ../../layouts/admin

block links
    link(rel="stylesheet", href="/css/components/admin/book.admin.css")


block content

    .page.page--appointment

        .appointment-header.page--appointment-block.page--block-1
            .appointment-header__top
                .appointment-header__top-name
                    h3 Appointment ##{user._id}
                .appointment-header__top-actions.flex
                    //- button(data-link=`/appointment/${user._id}/edit` data-method="").btn.secondary.flex-c.appointment-action Edit
                    if user.status === "confirmed"
                        button(data-link=`/appointment/${user._id}/cancel` data-method="PATCH" disabled=(grade === 'staff')).btn.secondary.appointment-action#cancelAppointment Cancel
                    button(data-link=`/appointment/${user._id}/delete` data-method="DELETE" disabled=(grade === 'staff')).btn.secondary.appointment-action#deleteAppointment Delete
                    if user.status === "confirmed"
                        button(data-link=`/appointment/${user._id}/send-reminder`).btn.appointment-action Send reminder
                    else 
                        button(data-link=`/appointment/${user._id}/restore` data-method="PATCH" disabled=(grade === 'staff')).btn.appointment-action#restoreAppointment Restore
                   
            .appointment-header__bottom.flex.col
                .appointment-header__bottom-col.flex.col
                    .appointment-header__bottom-col-element.flex
                        p.name-element Date:
                        p= user.date
                .appointment-header__bottom-col.flex.col
                    .appointment-header__bottom-col-element.flex
                        p.name-element Time:
                        p #{user.time}
                .appointment-header__bottom-col.flex.col
                    .appointment-header__bottom-col-element.flex
                        p.name-element Status:
                        p #{user.status.charAt(0).toUpperCase() + user.status.slice(1)}
        .appointment-details.appointment-details__client.page--appointment-block.page--block-3
            .appointment-details__header.flex
                svg(
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    )
                    path(d="M0 0h24v24H0V0z" fill="none")
                    path(d="M12 6c1.1 0 2 .9 2 2s-.9 2-2 2-2-.9-2-2 .9-2 2-2m0 10c2.7 0 5.8 1.29 6 2H6c.23-.72 3.31-2 6-2m0-12C9.79 4 8 5.79 8 8s1.79 4 4 4 4-1.79 4-4-1.79-4-4-4zm0 10c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z")
                h3 Client
            .appointment-details__separator
            .appointment-details__body
                .client-details.flex.col
                    .client-details__main.flex
                        .client-details__main-picture
                            img(src=user.avatar || "/images/no-user.webp" alt="user picture")
                        .client-details__main-locals.flex.col.space-b
                            h4 #{user.surname} #{user.name} 
                            p= user.email
                            p= user.phone

                    .client-details__second
                        .client-details__second-createdAt.flex
                            svg.icon
                            p Account created at: X
                        .client-details__second-createdAt.flex
                            svg.icon
                            p Total booking: X
                    //- button.btn.secondary Show profile
        .appointment-details.appointment-details__notes.page--appointment-block.page--block-3
            .appointment-details__header.flex
                svg(xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3")
                    path(d="M120-240v-80h480v80H120Zm0-200v-80h720v80H120Zm0-200v-80h720v80H120Z")
                h3 Notes
            .appointment-details__separator
            .appointment-details__body
                p - roekzroekroekroe 
                p - roekzroekroekroe 
        .appointment-details.appointment-details__service.page--appointment-block.page--block-3
            .appointment-details__header.flex
                svg(xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3")
                    path(d="m720-430 80 80v190q0 33-23.5 56.5T720-80H160q-33 0-56.5-23.5T80-160v-560q0-33 23.5-56.5T160-800h220q-8 18-12 38.5t-6 41.5H160v560h560v-270Zm52-174 128 128-56 56-128-128q-21 12-45 20t-51 8q-75 0-127.5-52.5T440-700q0-75 52.5-127.5T620-880q75 0 127.5 52.5T800-700q0 27-8 51t-20 45Zm-81-25q29-29 29-71t-29-71q-29-29-71-29t-71 29q-29 29-29 71t29 71q29 29 71 29t71-29ZM160-430v270-560 280-12 22Z")
                h3 Coming soon
            .appointment-details__separator
            .appointment-details__body 
                p Coming Soon...

block scripts
    script(src="/js/layouts/appointment.js" type="module")